<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="memberMapper">
	<select id="selectMemberById" parameterType="string" resultType="Member$login" >
		select *
		from MEMBERS
		where ID = #{userId}
	</select>
	
	<insert id="insertMember" parameterType="Member$newAccount" >
		<selectKey keyProperty="memberNo" resultType="int" order="BEFORE">
			SELECT SEQ_MEMBERS.nextval FROM DUAL
		</selectKey>
		insert into MEMBERS (
			MEMBER_NO
			,ID
			,PWD
			,NAME
			)
		values
			#{memberNo}
			,#{userId}
			,#{userPwd}
			,#{userName}
	</insert>
</mapper>
